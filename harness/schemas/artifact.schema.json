{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenChipAgent Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["path", "type", "stage", "required"],
  "properties": {
    "path": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": [
        "goal",
        "spec",
        "rtl",
        "testbench",
        "script",
        "log",
        "metadata",
        "report",
        "waveform",
        "coverage",
        "netlist",
        "def",
        "gds",
        "lef",
        "lib",
        "spice",
        "sdf",
        "spef",
        "drc_report",
        "lvs_report",
        "antenna_report",
        "other"
      ]
    },
    "stage": {
      "type": "string",
      "enum": ["probe", "spec", "rtl", "lint", "simulation", "synthesis", "pnr", "physical_verification", "gds", "report"]
    },
    "produced_by": { "type": ["string", "null"] },
    "required": { "type": "boolean" },
    "checksum": { "type": ["string", "null"] }
  }
}
