{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenChipAgent Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "goal_id",
    "status",
    "started_at",
    "ended_at",
    "tool_versions",
    "commands",
    "checks",
    "artifacts",
    "failures",
    "repairs",
    "final_report"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "goal_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["running", "passed", "failed", "blocked", "needs_review"]
    },
    "started_at": { "type": "string" },
    "ended_at": { "type": ["string", "null"] },
    "tool_versions": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "command.schema.json" }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "stage", "status", "required"],
        "properties": {
          "id": { "type": "string" },
          "stage": {
            "type": "string",
            "enum": ["probe", "spec", "rtl", "lint", "simulation", "synthesis", "pnr", "physical_verification", "gds", "report"]
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped", "blocked", "needs_tooling", "needs_review", "not_run"]
          },
          "required": { "type": "boolean" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "artifact.schema.json" }
    },
    "failures": {
      "type": "array",
      "items": { "$ref": "failure.schema.json" }
    },
    "repairs": {
      "type": "array",
      "items": { "$ref": "repair-action.schema.json" }
    },
    "final_report": { "type": "string" }
  }
}
