{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenChipAgent Goal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "description",
    "target",
    "constraints",
    "acceptance_checks",
    "done_when",
    "max_retries",
    "human_review_gates"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module_name", "language", "top_file"],
      "properties": {
        "module_name": { "type": "string", "minLength": 1 },
        "language": {
          "type": "string",
          "enum": ["verilog", "systemverilog", "mixed"]
        },
        "top_file": { "type": "string", "minLength": 1 }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true,
      "required": ["clock", "reset", "interfaces"],
      "properties": {
        "clock": { "type": "string", "minLength": 1 },
        "reset": { "type": "string", "minLength": 1 },
        "interfaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "latency": { "type": "string" },
        "synthesis_subset": { "type": "string" }
      }
    },
    "acceptance_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "stage", "required"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "stage": {
            "type": "string",
            "enum": ["probe", "spec", "rtl", "lint", "simulation", "synthesis", "pnr", "physical_verification", "gds", "report"]
          },
          "description": { "type": "string" },
          "required": { "type": "boolean" }
        }
      }
    },
    "done_when": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "max_retries": { "type": "integer", "minimum": 0 },
    "human_review_gates": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
